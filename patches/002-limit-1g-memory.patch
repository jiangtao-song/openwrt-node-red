diff -Nur root/etc/init.d/node-red.orig root/etc/init.d/node-red
--- root/etc/init.d/node-red.orig
+++ root/etc/init.d/node-red
@@ -4,11 +4,14 @@
 START=99
 STOP=10

 USE_PROCD=1

 start_service() {
 	procd_open_instance
-	procd_set_param command /usr/bin/node /usr/lib/node_modules/node-red/red.js
+	# V8堆内存限制1GB
+	procd_set_param command /usr/bin/node --max-old-space-size=1024 /usr/lib/node_modules/node-red/red.js
 	procd_set_param env HOME=/root
+	# procd硬限制进程物理内存1024MB(单位KB)
+	procd_set_param limits rss="1048576 1048576"
 	procd_set_param respawn
 	procd_close_instance
 }
